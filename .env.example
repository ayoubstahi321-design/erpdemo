# Supabase Configuration for Frontend
# IMPORTANT: Never commit the actual .env file with real credentials
# This is an example file. Copy it to .env and fill in your actual values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Note: The VITE_ prefix is required for Vite to expose these variables to the browser
# Only include public API keys here - never include service role keys in frontend .env
