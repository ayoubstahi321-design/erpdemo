# ============================================
# CONFIGURACIÓN DE BACKUP - AZMOL ERP
# ============================================
#
# IMPORTANTE: Copiar a .env.backup y rellenar valores reales
# NO subir a Git - agregar .env.backup a .gitignore

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
SUPABASE_DB_PASSWORD=tu_password_base_datos

# Google Drive API
# Obtener en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# Google Drive - ID de carpeta existente (OPCIONAL)
# Si especificas un ID, los backups se guardarán en esa carpeta
# Si no, se creará automáticamente una carpeta nueva "AZMOL_ERP_BACKUPS"
# Ejemplo: GOOGLE_DRIVE_FOLDER_ID=1h-kJ2GVVNQwiwOIgjfMGfjVtRs8K2Kl0
GOOGLE_DRIVE_FOLDER_ID=

# Cifrado de Backups
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=generar_clave_aleatoria_64_caracteres_hexadecimal_aqui

# Notificaciones (Opcional)
NOTIFICATION_EMAIL=tu-email@ejemplo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu_password_app

# Telegram (Opcional)
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id
